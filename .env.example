# Savage Flow Automation - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Gmail Configuration
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password-here
GMAIL_SENDER_FILTER=tictoctrading@substack.com

# Notion Configuration
NOTION_API_KEY=your-notion-api-key-here
NOTION_DATABASE_ID=your-notion-database-id-here

# Anthropic API Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Slack Configuration (Optional - for mobile notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Slack File Upload (Optional - requires Bot Token for file uploads)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_CHANNEL_ID=C01234567890
